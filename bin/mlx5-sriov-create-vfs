#!/usr/bin/env bash
#
# Create SR-IOV virtual functions on the Mellanox PF named by $1 and give each
# one a deterministic, locally-administered MAC address.
#
# Driven by the template unit mlx5-sriov-vfs@<pf-interface>.service -- one PF =
# one enabled instance. This is the "early" half of the setup: it MUST run
# before the network is brought up, because switchdev mode produces one
# representor netdev per VF and those representors are enslaved into a vlan-aware
# bridge in /etc/network/interfaces. The Proxmox resource-mapping half lives in
# mlx5-sriov-sync-mappings (mlx5-sriov-mappings@<pf>.service) and runs later, after
# pmxcfs is up -- the two cannot share a unit because pve-cluster is ordered
# After=network.target while this must run before networking.
#
# refs:
#   https://enterprise-support.nvidia.com/s/article/HowTo-Configure-SR-IOV-for-ConnectX-4-ConnectX-5-ConnectX-6-with-KVM-Ethernet
#   https://shawnliu.me/post/configuring-sr-iov-for-mellanox-adapters/

set -euo pipefail

pf="${1:?usage: ${0##*/} <pf-interface>}"

# Optional per-PF overrides (VF_COUNT, VF_MAC_PREFIX). Absent file is fine.
if [ -r "/etc/default/mlx5-sriov.d/$pf" ]; then
	# shellcheck source=/dev/null
	. "/etc/default/mlx5-sriov.d/$pf"
fi

dev_path="/sys/class/net/$pf/device"

# PCI address of the PF, derived from the interface.
pf_pci="$(basename "$(readlink -f "$dev_path")")"

# VF count: default to a modest value capped to the hardware maximum, and
# validate any explicit value against the ceiling and the MAC scheme.
total_vfs="$(cat "$dev_path/sriov_totalvfs")"
: "${VF_COUNT:=$(( total_vfs < 32 ? total_vfs : 32 ))}"
if [ "$VF_COUNT" -gt "$total_vfs" ]; then
	echo "VF_COUNT=$VF_COUNT exceeds hardware maximum ($total_vfs) on $pf" >&2
	exit 1
fi
if [ "$VF_COUNT" -gt 256 ]; then
	echo "VF_COUNT=$VF_COUNT > 256: the VF index is the final MAC octet" >&2
	exit 1
fi

# VF MAC prefix: if not configured, derive a stable locally-administered
# 5-octet prefix from this PF's permanent MAC. Hash the whole MAC so cards with
# sequential factory MACs don't collide on the prefix; derivation is per-PF, so
# multiple PFs/cards get distinct prefixes automatically.
if [ -z "${VF_MAC_PREFIX:-}" ]; then
	# "Permanent address: aa:bb:..."; take the last field, "" if no output.
	pf_mac="$(ethtool -P "$pf" 2>/dev/null)"
	pf_mac="${pf_mac##* }"
	case "$pf_mac" in
		"" | 00:00:00:00:00:00) pf_mac="$(cat "/sys/class/net/$pf/address")" ;;
	esac
	h="$(printf '%s' "$pf_mac" | sha256sum)"
	o0=$(( (0x${h:0:2} & 0xFE) | 0x02 ))   # clear multicast, set locally-administered
	VF_MAC_PREFIX="$(printf '%02x:%s:%s:%s:%s' "$o0" "${h:2:2}" "${h:4:2}" "${h:6:2}" "${h:8:2}")"
	echo "derived VF_MAC_PREFIX=$VF_MAC_PREFIX from PF $pf ($pf_mac)"
fi

echo "creating $VF_COUNT VFs on $pf ($pf_pci), MAC prefix $VF_MAC_PREFIX"

# Put the embedded eswitch into switchdev mode, then re-create the VFs.
devlink dev eswitch set "pci/$pf_pci" mode switchdev
echo 0           > "$dev_path/sriov_numvfs"
echo "$VF_COUNT" > "$dev_path/sriov_numvfs"

for ((i = 0; i < VF_COUNT; i++)); do
	# Final octet = VF index.
	mac="$(printf '%s:%02x' "$VF_MAC_PREFIX" "$i")"

	# Read the VF's PCI slot from its uevent (single read, no cat|grep).
	slot=""
	while IFS='=' read -r key val; do
		if [ "$key" = PCI_SLOT_NAME ]; then slot="$val"; fi
	done < "$dev_path/virtfn$i/uevent"

	# In switchdev mode the administrative VF MAC only takes effect across a
	# driver rebind of that VF.
	echo "$slot" > /sys/bus/pci/drivers/mlx5_core/unbind
	ip link set "$pf" vf "$i" mac "$mac"
	echo "$slot" > /sys/bus/pci/drivers/mlx5_core/bind
done

# Creating the VFs above emits udev 'add' events for the representor netdevs,
# and 70-mlx5-vf-representors.rules renames them (eth* -> sw<tag>pfNvfM) on those
# events -- asynchronously. This unit runs Before=network-pre.target, so without
# a barrier the bridge can come up and try to enslave representors by their
# stable names before the rename has landed, leaving the bridge with no VF ports.
# Drain the udev queue so the renames are done before we report success. Bounded
# and non-fatal: a settle timeout must not fail VF provisioning or block boot.
udevadm settle --timeout=30 || true
