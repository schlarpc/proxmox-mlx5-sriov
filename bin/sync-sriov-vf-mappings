#!/usr/bin/env bash
#
# Sync Proxmox PCI resource mappings (sriov-<iface>-vfN) for the SR-IOV VFs.
#
# This is the "late" half of the setup: it talks to pmxcfs via pvesh, so it
# must run after pve-cluster.service is up. It is split out from
# create-sriov-vfs precisely because that one runs before networking, whereas
# pve-cluster is ordered After=network.target.
#
# Idempotent: updates a mapping in place if it already exists, creates it
# otherwise. Safe to run repeatedly and against a live node -- it never leaves
# a mapping deleted, so a guest that (re)starts mid-run still finds its VF.

set -euo pipefail

# Host configuration (dpkg conffile).
[ -r /etc/default/sriov-vfs ] && . /etc/default/sriov-vfs
: "${PF_INTERFACE:?set PF_INTERFACE in /etc/default/sriov-vfs}"

mapping_prefix="sriov-$PF_INTERFACE-"
node="$(hostname)"
dev_path="/sys/class/net/$PF_INTERFACE/device"

# Authoritative VF count = however many VFs actually exist right now, not a
# configured number (keeps this in lockstep with what create-sriov-vfs made).
vf_count="$(cat "$dev_path/sriov_numvfs")"

for ((i = 0; i < vf_count; i++)); do
	slot="" pci_id="" subsys=""
	while IFS='=' read -r key val; do
		case "$key" in
			PCI_SLOT_NAME) slot="$val" ;;
			PCI_ID)        pci_id="${val,,}" ;;
			PCI_SUBSYS_ID) subsys="${val,,}" ;;
		esac
	done < "$dev_path/virtfn$i/uevent"

	group="$(basename "$(readlink -f "$dev_path/virtfn$i/iommu_group")")"
	id="${mapping_prefix}vf$i"
	map="node=$node,path=$slot,id=$pci_id,subsystem-id=$subsys,iommugroup=$group"

	if pvesh get "/cluster/mapping/pci/$id" --output-format json >/dev/null 2>&1; then
		pvesh set    "/cluster/mapping/pci/$id" --map "$map"
	else
		pvesh create /cluster/mapping/pci --id "$id" --map "$map"
	fi
done
